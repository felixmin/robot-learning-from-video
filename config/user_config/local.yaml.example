# @package _global_
# User-specific configuration overrides
# Copy this file to local.yaml (in this same directory) and customize for your environment.
#
# This file is gitignored so your local paths won't be committed.
#
# The config is automatically included (as optional) by experiment configs that need it.
# You can also override via CLI:
#   python scripts/2_train_stage1_lam.py experiment=stage1_local logging.root_dir=/my/path

# Logging paths (where to store run outputs)
logging:
  # Base directory for all run artifacts (runs/, cache/, etc.)
  # Set this to a directory with plenty of storage space.
  # Examples:
  #   - Local: /home/username/experiments/hlrp
  #   - LRZ DSS: /dss/dssmcmlfs01/pn57pi/pn57pi-dss-0001/username
  root_dir: null
  # Usually you do not need to set `runs_dir` manually.
  # By default it is derived from `logging.root_dir` as:
  #   ${logging.root_dir}/runs/${now:%Y-%m-%d_%H-%M-%S}_${experiment.name}

# Cache directory for large downloads (HF hub weights, torch hub, TFDS cache, etc.).
# If relative, resolved against `logging.root_dir`.
paths:
  cache_dir: cache

# Optional: user-local artifact defaults used by profiles that need a
# long-lived checkpoint. This is the right place for machine-specific
# reused artifacts, for example a preferred Stage 1 LAM checkpoint that
# Stage 3 multitask runs should use by default.
artifacts:
  lam_checkpoint_path: null  # e.g. /mnt/data/workspace/runs_root/runs/.../checkpoints/last.ckpt

# Optional: set your own imported unified cluster image here.
# Most experiments include this file as optional `/user_config: local`,
# so this value cleanly overrides the shared `cluster.container.image: null`.
# In the normal LRZ workflow this file is the default activation target for the
# deployment helper, which archives the previous image into `enroot/old/` and
# updates this path to the new imported `.sqsh`. Ad hoc CLI overrides can still
# bypass it for one-off submissions.
# See containers/README.md for the build/push/import/archive workflow.
cluster:
  container:
    image: null            # e.g. /dss/.../enroot/hlrp_unified_cu128_imported_2026-03-14_2248.sqsh
